.env
*.db
venv/
# The image's venv lives at /opt/venv (UV_PROJECT_ENVIRONMENT in the Dockerfile);
# a host .venv swept in by `COPY . .` would bake a wrong (dev-including,
# host-platform) interpreter tree into the image.
.venv/
__pycache__/
.git/
tests/
*.pyc
caddy/certs/
# pg_dump archives of the live database written by the Compose `backup` service
# (#86, `./backups:/backups`). `.gitignore` does not affect the Docker build
# context, so without this the documented `docker compose up --build` upgrade
# path bakes every production dump — user rows, bcrypt hashes, webhook URLs —
# into the app image layers (#277).
backups/
DEPLOYMENT.md
