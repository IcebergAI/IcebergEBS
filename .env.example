# PostgreSQL
POSTGRES_DB=iceberg_ebs
POSTGRES_USER=iceberg_ebs
POSTGRES_PASSWORD=<generate: openssl rand -hex 32>

# IcebergEBS app
ICEBERG_EBS_ADMIN_USERNAME=admin
ICEBERG_EBS_ADMIN_PASSWORD=<strong password>
ICEBERG_EBS_SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">
ICEBERG_EBS_APP_BASE_URL=https://your-domain.example.com

# Data retention (optional): prune FetchLog / InstallCountHistory / AlertLog rows
# older than this many days. 0 / unset disables pruning. Recommended for a real
# watchlist so the history tables don't grow unbounded. The Compose stack forwards
# this into the app container (#87); uncomment to enable.
# ICEBERG_EBS_RETENTION_DAYS=90

# Watchlist refresh interval in minutes (optional; default 60). Forwarded by the
# Compose stack (#87).
# ICEBERG_EBS_FETCH_INTERVAL_MINUTES=60

# Test database (dev only): the pytest suite runs against a real Postgres. The dev
# stack (docker-compose.dev.yml) publishes one on localhost; point the suite at it.
# Used by `make test`. Defaults to the app's ICEBERG_EBS_DATABASE_URL when unset.
# ICEBERG_EBS_TEST_DATABASE_URL=postgresql+asyncpg://iceberg_ebs:iceberg_ebs@localhost:5432/iceberg_ebs
